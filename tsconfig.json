{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "importHelpers": true
  },
  "include": [
    "./index.ts",
    "./lib/**/*",
    "./test/**/*.unit.ts",
    "./test/**/*.e2e.ts",
    "./test/**/*.int.ts",
    "./test/**/*.ext.ts",
    "./test/util.ts",
    "./test/integration/**/*",
    "./test/fixtures/**/*",
    "./test/constants.ts",
    "./test/agents/**/*",
    "./test/agent-downloaders/**/*",
    "./test/scout/**/*",
    "./test/integrations/**/*"
  ]
}
