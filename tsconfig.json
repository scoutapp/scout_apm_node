{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "es6",
    "module": "commonjs",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "lib": [ "es2017", "dom" ]
  },
  "include": [
    "./index.ts",
    "./lib/**/*",
    "./test/**/*.unit.ts",
    "./test/**/*.e2e.ts",
    "./test/**/*.int.ts",
    "./test/**/*.ext.ts",
    "./test/util.ts",
    "./test/integration/**/*",
    "./test/fixtures/**/*",
    "./test/constants.ts",
    "./test/agents/**/*",
    "./test/agent-downloaders/**/*",
    "./test/scout/**/*",
    "./test/integrations/**/*"
  ]
}
