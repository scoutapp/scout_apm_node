  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build-watch": "tsc --watch -p tsconfig.json",
    "lint": "tslint -p tsconfig.json",
    "test": "npm run lint && npm run test-unit && npm run test-int && npm run test-e2e && npm run test-integration-pg && npm run test-integration-mysql",
    "test-unit": "tape 'dist/test/**/*.unit.js'",
    "test-int": "tape 'dist/test/**/*.int.js'",
    "test-e2e": "tape 'dist/test/**/*.e2e.js'",
    "test-e2e-without-integration": "tape 'dist/test/*.e2e.js' 'dist/test/agents/**/*.e2e.js' 'dist/test/agent-downloaders/**/*.e2e.js' 'dist/test/scout/**/*.e2e.js'",
    "test-ext": "tape 'dist/test/**/*.ext.js'",
    "test-ext-memory": "tape 'dist/test/memory.ext.js'",
    "test-ext-dashboard-send": "tape 'dist/test/dashboard-send.ext.js'",
    "test-integration": "tape 'dist/test/integrations/*.e2e.js'",
    "test-integration-pg": "tape 'dist/test/integrations/pg.e2e.js'",
    "test-integration-mysql": "tape 'dist/test/integrations/mysql.e2e.js'",
    "test-integration-mysql2": "tape 'dist/test/integrations/mysql2.e2e.js'",
    "test-integration-pug": "tape 'dist/test/integrations/pug.e2e.js'",
    "test-integration-mustache": "tape 'dist/test/integrations/mustache.e2e.js'",
    "test-integration-ejs": "tape 'dist/test/integrations/ejs.e2e.js'",
    "test-integration-express": "tape 'dist/test/integrations/express.e2e.js'",
    "test-integration-nuxt": "tape 'dist/test/integrations/nuxt.e2e.js'",
    "test-integration-ioredis": "tape 'dist/test/integrations/ioredis.e2e.js'",
    "test-integration-nest": "tape 'dist/test/integrations/nest.e2e.js'",
    "test-integration-prisma": "tape 'dist/test/integrations/prisma.e2e.js'",
    "test-integration-redis": "tape 'dist/test/integrations/redis.e2e.js'",
    "test-integration-mongodb": "tape 'dist/test/integrations/mongodb.e2e.js'",
    "generate": "prisma generate"
  },
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": "./dist/lib/index.js",
    "./preload": "./dist/lib/preload.js"
  },
  "files": [
    "index.d.ts",
    "dist/lib/**/*"
  ],
