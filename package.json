    "ioredis": "^5.0.0",
    "loadtest": "^8.0.9",
    "mustache": "^4.2.0",
    "mustache-express": "^1.3.2",
    "mysql": "^2.18.1",
    "mysql2": "^3.11.5",
    "nuxt": "^2.18.1",
    "pg": "^8.13.1",
    "prisma": "^5.22.0",
    "pug": "^3.0.3",
    "randomstring": "^1.3.0",
    "sequelize": "^6.37.5",
